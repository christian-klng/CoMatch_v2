# Postgres connection (Coolify gives you this for the Postgres service)
DATABASE_URL=postgres://comatch:password@localhost:5432/comatch

# HTTP port the API listens on
PORT=3000

# Allowed CORS origins, comma-separated (frontend AND admin URL).
# Use * only for local dev.
CORS_ORIGIN=http://localhost:5173

# --- Auth (magic link) ---
# Secret for signing session JWTs. Use a long random string (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string
# Public frontend base URL — used to build the magic-link target (/auth/verify).
APP_URL=http://localhost:5173

# --- SMTP (magic-link emails) ---
# If these are unset, the magic link is logged to the API console instead (dev only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CoMatch <no-reply@comatch.app>

# --- Mistral (skill suggestions + bilingual label translation) ---
# If unset, suggestion generation returns 503 and labels stay untranslated.
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-medium-latest

# --- Unipile (LinkedIn profile import) ---
# If unset, the LinkedIn connect step reports the import as unavailable.
UNIPILE_DSN=
UNIPILE_API_KEY=
UNIPILE_ACCOUNT_ID=
